{
  "name": "influenceos-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "build": "npm run build --workspace=frontend && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "npm run lint --workspace=frontend",
    "db:migrate:local": "wrangler d1 execute influenceos-db --local --file=./schema.sql"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.3",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "wrangler": "^4.110.0"
  }
}
